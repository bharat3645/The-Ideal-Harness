{
  "name": "@ideal-harness/compress",
  "version": "0.1.0",
  "type": "module",
  "description": "The Ideal Harness context compression: deterministic tool_result compression (row-sampling, log-RLE, error-collapse), prompt-cache-safe, with a Compress-Cache-Retrieve (CCR) store for lossless recovery.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "ideal-harness-compress": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin"
  ],
  "dependencies": {
    "@ideal-harness/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\"",
    "clean": "rm -rf dist dist-test"
  }
}
