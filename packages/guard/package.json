{
  "name": "@ideal-harness/guard",
  "version": "0.1.0",
  "type": "module",
  "description": "The Ideal Harness enforcement floor: deny-wins policy engine, permission defaults, injection defense, secret redaction + broker, skill vetting, drift-guard, sandbox command builder. Everything deterministic, below the LLM.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bharat3645/The-Ideal-Harness.git",
    "directory": "packages/guard"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "ideal-harness-guard": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "hooks",
    ".claude-plugin"
  ],
  "dependencies": {
    "@ideal-harness/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\"",
    "clean": "rm -rf dist dist-test"
  }
}
