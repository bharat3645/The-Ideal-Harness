{
  "name": "@ideal-harness/core",
  "version": "0.1.0",
  "type": "module",
  "description": "The Ideal Harness substrate: plugin loader, schema validation, skill templating + multi-host generation, shared runtime primitives.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./skills": "./dist/skills/index.js"
  },
  "bin": {
    "ideal-harness": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skills",
    "hooks",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\"",
    "clean": "rm -rf dist dist-test"
  }
}
